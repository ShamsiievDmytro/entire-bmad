---
import '../styles/global.css';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';
import '@fontsource/jetbrains-mono/600.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import Nav from '../components/Nav.astro';
---

<html lang="en" style="background-color: #f5f5f5">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>AI Metrics — Metrics</title>
  </head>
  <body class="min-h-dvh px-4 sm:px-6 lg:px-8 py-6 sm:py-12" style="background-color: #f5f5f5; color: #1a1a2e">
    <div class="w-full max-w-[1280px] mx-auto">
      <Nav />
      <main>
        <slot />
      </main>
    </div>
  </body>
</html>
